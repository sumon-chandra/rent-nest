model User {
   id String @id @default(cuid())

   name     String
   email    String @unique
   password String

   phone  String?
   avatar String?

   role   Role       @default(TENANT)
   status UserStatus @default(ACTIVE)

   createdAt DateTime @default(now())
   updatedAt DateTime @updatedAt

   // Relations

   properties     Property[]
   rentalRequests RentalRequest[]
   reviews        Review[]

   @@map("users")
}
